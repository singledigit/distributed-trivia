# Copy to samconfig.toml and update with your values
version = 0.1

[default.global.parameters]
stack_name = "trivia"
region = "us-west-2"
profile = "your-aws-profile"

[default.build.parameters]
parallel = true
cached = true

[default.deploy.parameters]
stack_name = "trivia"
region = "us-west-2"
profile = "your-aws-profile"
resolve_s3 = true
capabilities = "CAPABILITY_IAM"
confirm_changeset = true
